# ============================================
# VentaFlow — Configuración de Entorno
# ============================================
# Copia este archivo como .env.local y completa los valores

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# Solo en servidor (nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- App ---
NEXT_PUBLIC_APP_URL=https://ventaflow.cl
NEXT_PUBLIC_APP_NAME=VentaFlow

# Plan: starter | pro | enterprise
NEXT_PUBLIC_PLAN=pro

# --- Resend (envío de emails) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=

# --- SumUp Integration (pagos con tarjeta) ---
SUMUP_CLIENT_ID=tu_client_id
SUMUP_CLIENT_SECRET=tu_client_secret
SUMUP_MERCHANT_CODE=tu_merchant_code

# --- WhatsApp Business API (Meta) ---
WHATSAPP_TOKEN=tu_token_permanente_meta
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_VERIFY_TOKEN=un_string_secreto_para_webhook
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_TEMPLATE_LANGUAGE=es_CL
WHATSAPP_TEMPLATE_LINK_PAGO=link_pago
WHATSAPP_TEMPLATE_PEDIDO_LISTO=

# --- Gmail API (verificación automática de transferencias) ---
GMAIL_CLIENT_ID=tu_client_id_google
GMAIL_CLIENT_SECRET=tu_client_secret_google
GMAIL_REFRESH_TOKEN=tu_refresh_token_google

# --- Cron Secret ---
CRON_SECRET=un_string_secreto_para_cron
